{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react", "jsx-a11y", "import"],
  "categories": {
    "correctness": "error"
  },
  "options": {
    "typeAware": true,
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    // Kubus uses TypeScript's automatic JSX runtime (`jsx: react-jsx`).
    "react/react-in-jsx-scope": "off",
    // High-signal React correctness and performance checks outside the
    // default correctness category.
    "react/rules-of-hooks": "error",
    "react/no-unstable-nested-components": "error",
    "react/jsx-no-constructed-context-values": "error",
    "react/no-object-type-as-default-prop": "error"
  },
  "overrides": [
    {
      // These modal surfaces intentionally move focus to their primary control.
      "files": [
        "client/src/components/ConfirmDialog.tsx",
        "client/src/components/FileCopyDialog.tsx",
        "client/src/components/RowActions.tsx",
        "client/src/layout/SearchDialog.tsx"
      ],
      "rules": {
        "jsx-a11y/no-autofocus": "off"
      }
    },
    {
      // Vite's `?worker` modules synthesize default Worker constructors.
      "files": ["client/src/monaco-setup.ts"],
      "rules": {
        "import/default": "off"
      }
    }
  ]
}
