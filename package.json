{
  "name": "kubus",
  "version": "0.2.4",
  "private": true,
  "description": "Free, open-source Kubernetes GUI — multi-cluster browsing, logs, exec, port-forward, metrics, Helm",
  "license": "MIT",
  "engines": {
    "node": ">=24.17.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "start": "node server/dist/index.js",
    "electron": "pnpm build && pnpm --filter @kubus/electron start",
    "dist": "pnpm build && pnpm --filter @kubus/electron dist",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "serve-docs": "uvx --native-tls zensical serve --open",
    "build-docs": "uvx --native-tls zensical build --clean"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1",
    "typescript": "^6.0.3"
  }
}
