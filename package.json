{
  "name": "kubedeck",
  "version": "0.1.1",
  "private": true,
  "description": "Free, open-source Kubernetes GUI — multi-cluster browsing, logs, exec, port-forward, metrics, Helm",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "start": "node server/dist/index.js",
    "electron": "pnpm build && pnpm --filter @kubedeck/electron start",
    "dist": "pnpm build && pnpm --filter @kubedeck/electron dist",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0",
    "typescript": "^5.8.3"
  }
}
